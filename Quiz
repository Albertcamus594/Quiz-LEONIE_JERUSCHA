  return `<svg viewBox="0 0 900 320" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="${escapeHtml(category)}">
    <defs><linearGradient id="g" x1="0" y1="0" x2="1" y2="1"><stop stop-color="${v.color1}"/><stop offset="1" stop-color="${v.color2}"/></linearGradient></defs>
    <rect width="900" height="320" fill="url(#g)"/><circle cx="760" cy="70" r="120" fill="rgba(255,255,255,.18)"/><circle cx="115" cy="255" r="160" fill="rgba(255,255,255,.11)"/>
    <text x="50%" y="44%" text-anchor="middle" dominant-baseline="middle" font-size="${iconSize}">${v.icon}</text>
    <text x="50%" y="70%" text-anchor="middle" fill="white" font-family="Arial" font-size="38" font-weight="800">${escapeHtml(category)}</text>
  </svg>`;
}
function renderHomeVisual(){ $("homeVisual").innerHTML = visualSvg("Symboles et valeurs", true); }

const PLAYFUL_CATEGORIES = new Set(["Symboles et valeurs","Histoire","Europe","Vie citoyenne","Élections","Institutions","Administration","Éducation","Travail"]);
const FUNNY_TIPS = [
  (t,a)=>`Astuce pour ne plus jamais l’oublier : associe « ${t} » à « ${a} » et répète-le à voix haute, façon formule magique. 🪄`,
  (t,a)=>`Petit moyen mnémo : imagine « ${t} » avec une pancarte géante sur laquelle est écrit « ${a} ». Ridicule, mais ça marche.`,
  (t,a)=>`Retiens ça comme une punchline : « ${t} » ? Eh bien « ${a} », évidemment ! Ressors-la au prochain repas de famille.`,
  (t,a)=>`Truc pour la mémoire : colle un post-it mental sur « ${t} » avec « ${a} » écrit en lettres capitales.`,
  (t,a)=>`Mnémotechnique express : la prochaine fois qu’on te parle de « ${t} », ton cerveau doit crier « ${a} » avant la fin de la phrase.`,
  (t,a)=>`Pour épater tout le monde plus tard : « ${t} », c’est « ${a} ». Sors ça d’un air détaché, effet garanti.`
];
const SERIOUS_TIPS = [
  (t,a)=>`Point à retenir sérieusement : « ${t} » → ${a}. C’est une notion qui revient souvent, prends le temps de la fixer.`,
  (t,a)=>`Repère utile : sur « ${t} », la bonne réponse est « ${a} ». Relis l’explication une seconde fois si besoin.`,
  (t,a)=>`À mémoriser calmement : « ${t} » correspond à « ${a} ». Ce sujet mérite d’être bien compris, pas seulement appris par cœur.`,
  (t,a)=>`Pense-bête : garde en tête que « ${t} » = « ${a} ». Reviens-y si le doute revient au prochain quiz.`
];
function generateMemoTip(q){
  const pool = PLAYFUL_CATEGORIES.has(q.category) ? FUNNY_TIPS : SERIOUS_TIPS;
  const pick = pool[Math.floor(Math.random()*pool.length)];
  return pick(q.title, q.answer);
}

function shapeSvg(ok){
  if(ok){
    return `<svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
      <defs><linearGradient id="okg" x1="0" y1="0" x2="1" y2="1"><stop stop-color="#8ef0bb"/><stop offset="1" stop-color="#1fae63"/></linearGradient></defs>
      <circle cx="60" cy="60" r="54" fill="url(#okg)"/>
      <path d="M35 62 L52 79 L86 42" stroke="#08221a" stroke-width="9" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>`;
  }
  return `<svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
    <defs><linearGradient id="kog" x1="0" y1="0" x2="1" y2="1"><stop stop-color="#ffb199"/><stop offset="1" stop-color="#ff6b6b"/></linearGradient></defs>
    <circle cx="60" cy="60" r="54" fill="url(#kog)"/>
    <path d="M42 42 L78 78 M78 42 L42 78" stroke="#3a0e0e" stroke-width="9" stroke-linecap="round"/>
  </svg>`;
}
function confettiHtml(){
  const colors = ['#f0c866','#7bb7ff','#44d07b','#ff9fb2','#c4b5fd'];
  let html = '';
  for(let i=0;i<14;i++){
    const angle = Math.random()*Math.PI*2;
    const dist = 55 + Math.random()*55;
    const dx = Math.cos(angle)*dist;
    const dy = Math.sin(angle)*dist - 15;
    const rot = Math.floor(Math.random()*360);
    const color = colors[i % colors.length];
    const delay = (Math.random()*0.15).toFixed(2);
    html += `<span style="background:${color};--dx:${dx.toFixed(0)}px;--dy:${dy.toFixed(0)}px;--rot:${rot}deg;animation-delay:${delay}s"></span>`;
  }
  return `<div class="confetti">${html}</div>`;
}
function showAnswerPopup(q, ok){
  $("popupShape").innerHTML = shapeSvg(ok) + (ok ? confettiHtml() : '');
  const titleEl = $("popupTitle");
  titleEl.textContent = ok ? "Bonne réponse !" : "Pas tout à fait…";
  titleEl.className = `popup-title ${ok ? 'ok' : 'ko'}`;
  $("popupAnswer").innerHTML = ok
    ? escapeHtml(q.explanation)
    : `Réponse correcte : <b>${escapeHtml(q.answer)}</b><br>${escapeHtml(q.explanation)}`;
  $("popupTip").innerHTML = `💡 ${escapeHtml(generateMemoTip(q))}`;
  $("popupContinueBtn").textContent = (currentIndex === QUIZ_SIZE - 1) ? "Voir la correction finale" : "Question suivante";
  $("popupOverlay").classList.add('open');
}
function closeAnswerPopup(){
  $("popupOverlay").classList.remove('open');
  currentIndex++;
  if(currentIndex >= QUIZ_SIZE) finishQuiz(); else renderQuestion();
}
function updateNameButtons(){
  document.querySelectorAll('.choice').forEach(btn => btn.classList.toggle('active', btn.dataset.name === selectedName));
  $("studentPill").textContent = `Candidate : ${selectedName}`;
}

document.querySelectorAll('.choice').forEach(btn => btn.addEventListener('click', () => {
  selectedName = btn.dataset.name; localStorage.setItem("ac_quiz_name", selectedName); updateNameButtons();
}));

function makeQuestion(raw){ return {...raw, shuffledOptions: shuffle(raw.options)}; }
function pickQuiz(){
  let pool = QUESTION_BANK.filter(q => !lastIds.includes(q.id));
  if(pool.length < QUIZ_SIZE) pool = QUESTION_BANK;
  const selected = shuffle(pool).slice(0, QUIZ_SIZE).map(makeQuestion);
  lastIds = selected.map(q => q.id);
  localStorage.setItem("ac_quiz_last_ids", JSON.stringify(lastIds));
  return selected;
}
function startQuiz(){
  currentQuiz = pickQuiz(); currentIndex = 0; answers = [];
  attempts += 1; localStorage.setItem("ac_quiz_attempts", String(attempts));
  home.style.display = "none"; result.style.display = "none"; quiz.style.display = "block";
  renderQuestion(); window.scrollTo({top:0, behavior:"smooth"});
}
function renderQuestion(){
  const q = currentQuiz[currentIndex];
  $("questionPill").textContent = `Question ${currentIndex+1}/${QUIZ_SIZE}`;
  $("bankPill").textContent = `Banque : ${QUESTION_BANK.length} questions`;
  $("progressFill").style.width = `${(currentIndex/QUIZ_SIZE)*100}%`;
  $("categoryLabel").textContent = q.category;
  $("questionText").textContent = q.question;
  $("questionVisual").innerHTML = visualSvg(q.category);
  $("options").innerHTML = q.shuffledOptions.map(opt => `<button class="option" type="button" data-answer="${escapeHtml(opt)}">${escapeHtml(opt)}</button>`).join("");
  document.querySelectorAll('.option').forEach(btn => btn.addEventListener('click', onOptionClick));
}
function onOptionClick(e){
  const chosenBtn = e.currentTarget;
  const q = currentQuiz[currentIndex];
  const answer = chosenBtn.dataset.answer;
  answers[currentIndex] = answer;
  const ok = answer === q.answer;
  document.querySelectorAll('.option').forEach(btn => {
    btn.disabled = true;
    if(btn.dataset.answer === q.answer) btn.classList.add('correct');
    else if(btn === chosenBtn) btn.classList.add('incorrect');
    else btn.classList.add('dimmed');
  });
  showAnswerPopup(q, ok);
}
function finishQuiz(){
  $("progressFill").style.width = "100%";
  quiz.style.display = "none"; result.style.display = "block";
  const good = currentQuiz.reduce((n,q,i)=> n + (answers[i] === q.answer ? 1 : 0), 0);
  const bad = QUIZ_SIZE - good;
  $("scoreText").textContent = `${good}/${QUIZ_SIZE}`;
  $("goodStat").textContent = good; $("badStat").textContent = bad; $("attemptStat").textContent = attempts;
  $("resultMessage").textContent = resultMessage(good);
  $("review").innerHTML = currentQuiz.map((q,i) => {
    const ok = answers[i] === q.answer;
    return `<div class="review-item ${ok?'correct':'wrong'}">
      <div class="review-head"><span>${i+1}. ${escapeHtml(q.question)}</span><span class="${ok?'ok':'ko'}">${ok?'Correct':'À revoir'}</span></div>
      <div class="small">Réponse de ${escapeHtml(selectedName)} : <b>${escapeHtml(answers[i] || 'Aucune')}</b></div>
      ${ok ? '' : `<div class="small">Bonne réponse : <b>${escapeHtml(q.answer)}</b></div>`}
      <div class="explain">${escapeHtml(q.explanation)}</div>
    </div>`;
  }).join("");
  saveLastResult(); window.scrollTo({top:0, behavior:"smooth"});
}
function resultMessage(score){
  if(score <= 10) return `${selectedName}, il faut reprendre les bases. L’objectif n’est pas d’aller vite, mais de comprendre les corrections.`;
  if(score <= 18) return `${selectedName}, c’est correct, mais il reste encore trop d’hésitations. Relance un nouveau quiz.`;
  if(score <= 24) return `${selectedName}, bon niveau. Les bases sont là, il faut maintenant sécuriser les détails.`;
  if(score <= 29) return `${selectedName}, très solide. Encore une ou deux séries et ce sera vraiment propre.`;
  return `${selectedName}, 30/30. Série validée. AC peut être fier de cette révision.`;
}
function summaryText(){
  const good = currentQuiz.reduce((n,q,i)=> n + (answers[i] === q.answer ? 1 : 0), 0);
  let txt = `Quiz civique préparé par AC\nCandidate : ${selectedName}\nScore : ${good}/${QUIZ_SIZE}\nTentative : ${attempts}\n\n`;
  currentQuiz.forEach((q,i)=>{ txt += `${i+1}. ${q.question}\nRéponse : ${answers[i]}\nBonne réponse : ${q.answer}\nExplication : ${q.explanation}\n\n`; });
  return txt;
}
function saveLastResult(){ localStorage.setItem("ac_quiz_last_result", summaryText()); }
function copyResult(){ navigator.clipboard.writeText(summaryText()).then(()=>alert("Résultat copié.")); }
function downloadResult(){
  const blob = new Blob([summaryText()], {type:"text/plain;charset=utf-8"});
  const url = URL.createObjectURL(blob); const a=document.createElement('a');
  a.href=url; a.download=`correction-${selectedName.toLowerCase()}-quiz-civique.txt`; a.click(); URL.revokeObjectURL(url);
}
function sendWhatsApp(){ window.open(`https://wa.me/${AC_WHATSAPP}?text=${encodeURIComponent(summaryText())}`, '_blank'); }
function clearHistory(){ if(confirm("Effacer l’historique local des tentatives ?")){ localStorage.removeItem("ac_quiz_attempts"); localStorage.removeItem("ac_quiz_last_ids"); localStorage.removeItem("ac_quiz_last_result"); attempts=0; lastIds=[]; alert("Historique effacé."); } }

$("startBtn").addEventListener('click', startQuiz);
$("newQuizBtn").addEventListener('click', startQuiz);
$("copyBtn").addEventListener('click', copyResult);
$("downloadBtn").addEventListener('click', downloadResult);
$("whatsappBtn").addEventListener('click', sendWhatsApp);
$("clearBtn").addEventListener('click', clearHistory);
$("popupContinueBtn").addEventListener('click', closeAnswerPopup);
document.addEventListener('keydown', e => {
  if(e.key === 'Enter' && $("popupOverlay").classList.contains('open')) closeAnswerPopup();
});
renderHomeVisual(); updateNameButtons();
</script>
</body>
</html>
